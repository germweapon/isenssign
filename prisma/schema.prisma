generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Auth & Multi-tenant
// ==========================================

model Account {
  id        String   @id @default(cuid())
  name      String?
  timezone  String   @default("Asia/Seoul")
  locale    String   @default("ko")
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  templates       Template[]
  templateFolders TemplateFolder[]
  submissions     Submission[]
  webhookUrls     WebhookUrl[]
  accountConfig   AccountConfig?
  apiTokens       ApiToken[]

  @@map("accounts")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  firstName     String
  lastName      String?
  passwordHash  String?
  role          UserRole  @default(MEMBER)
  avatarUrl     String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  templates        Template[]
  templateFolders  TemplateFolder[]
  submissions      Submission[]
  templateAccesses TemplateAccess[]
  sessions         Session[]

  @@map("users")
}

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  expires      DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model ApiToken {
  id        String   @id @default(cuid())
  name      String
  token     String   @unique
  lastUsed  DateTime?
  createdAt DateTime @default(now())

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("api_tokens")
}

// ==========================================
// Template System
// ==========================================

model TemplateFolder {
  id           String    @id @default(cuid())
  name         String
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accountId      String
  account        Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  authorId       String
  author         User            @relation(fields: [authorId], references: [id])
  parentFolderId String?
  parentFolder   TemplateFolder? @relation("FolderHierarchy", fields: [parentFolderId], references: [id])

  subfolders TemplateFolder[] @relation("FolderHierarchy")
  templates  Template[]

  @@map("template_folders")
}

model Template {
  id          String    @id @default(cuid())
  name        String
  schema      Json      @default("[]") // Field definitions
  documents   Json      @default("[]") // Attached document metadata
  preferences Json      @default("{}") // Template-level settings
  source      TemplateSource @default(NATIVE)
  archivedAt  DateTime?
  externalId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  authorId  String
  author    User    @relation(fields: [authorId], references: [id])
  folderId  String?
  folder    TemplateFolder? @relation(fields: [folderId], references: [id])

  submissions      Submission[]
  templateAccesses TemplateAccess[]
  templateSharings TemplateSharing[]
  attachments      Attachment[]

  @@map("templates")
}

enum TemplateSource {
  NATIVE
  API
  IMPORT
}

model TemplateAccess {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([templateId, userId])
  @@map("template_accesses")
}

model TemplateSharing {
  id        String   @id @default(cuid())
  slug      String   @unique
  submitters Json     @default("[]") // Pre-defined submitter roles
  expiresAt  DateTime?
  createdAt DateTime @default(now())

  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_sharings")
}

// ==========================================
// Submission & Signing
// ==========================================

model Submission {
  id              String           @id @default(cuid())
  slug            String           @unique @default(cuid())
  source          SubmissionSource @default(WEB)
  submitterOrder  SubmitterOrder   @default(RANDOM)
  status          SubmissionStatus @default(PENDING)
  completedAt     DateTime?
  archivedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  templateId String
  template   Template @relation(fields: [templateId], references: [id])
  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])

  submitters        Submitter[]
  submissionEvents  SubmissionEvent[]
  completedDocuments CompletedDocument[]

  @@map("submissions")
}

enum SubmissionSource {
  WEB
  API
  SHARE_LINK
  EMBED
}

enum SubmitterOrder {
  RANDOM
  SEQUENTIAL
}

enum SubmissionStatus {
  PENDING
  ACTIVE
  COMPLETED
  EXPIRED
  ARCHIVED
}

model Submitter {
  id            String          @id @default(cuid())
  slug          String          @unique @default(cuid())
  email         String?
  phone         String?
  name          String?
  role          String          @default("Signer")
  status        SubmitterStatus @default(PENDING)
  values        Json            @default("{}") // Filled field values
  metadata      Json            @default("{}")
  sentAt        DateTime?
  openedAt      DateTime?
  completedAt   DateTime?
  declinedAt    DateTime?
  externalId    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Verification info
  verificationMethod VerificationMethod?
  verificationId     String?   // Barocert receipt ID
  verifiedAt         DateTime?

  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  submitterEvents SubmitterEvent[]

  @@map("submitters")
}

enum SubmitterStatus {
  PENDING
  SENT
  OPENED
  COMPLETED
  DECLINED
}

enum VerificationMethod {
  NONE
  EMAIL
  SMS
  KAKAO_CERT
  NAVER_CERT
  TOSS_CERT
}

// ==========================================
// Events & Audit
// ==========================================

model SubmissionEvent {
  id        String   @id @default(cuid())
  eventType String   // created, sent, completed, expired, archived
  data      Json     @default("{}")
  createdAt DateTime @default(now())

  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("submission_events")
}

model SubmitterEvent {
  id        String   @id @default(cuid())
  eventType String   // sent, opened, signed, declined, verified
  data      Json     @default("{}")
  createdAt DateTime @default(now())

  submitterId String
  submitter   Submitter @relation(fields: [submitterId], references: [id], onDelete: Cascade)

  @@map("submitter_events")
}

// ==========================================
// Documents & Files
// ==========================================

model Attachment {
  id          String   @id @default(cuid())
  filename    String
  contentType String
  byteSize    Int
  storageKey  String   // S3 key or local path
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model CompletedDocument {
  id          String   @id @default(cuid())
  filename    String
  contentType String   @default("application/pdf")
  storageKey  String
  sha256      String?
  createdAt   DateTime @default(now())

  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("completed_documents")
}

// ==========================================
// Webhooks
// ==========================================

model WebhookUrl {
  id        String   @id @default(cuid())
  url       String
  events    String[] // Array of event types
  secret    String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("webhook_urls")
}

// ==========================================
// Account Configuration
// ==========================================

model AccountConfig {
  id        String   @id @default(cuid())
  // SMTP
  smtpHost     String?
  smtpPort     Int?
  smtpUser     String?
  smtpPassword String?
  smtpFromEmail String?

  // Kakao Alimtalk
  kakaoSenderKey    String?
  kakaoChannelId    String?

  // Barocert
  barocertClientCode String?
  barocertSecretKey  String?

  // Storage
  storageProvider String @default("local") // local, s3
  s3Bucket        String?
  s3Region        String?
  s3AccessKey     String?
  s3SecretKey     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("account_configs")
}
